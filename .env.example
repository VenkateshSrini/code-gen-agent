###############################################################################
#                     AI Code Generator - Environment Setup                    #
#                                                                              #
#  Copy this file to .env and fill in the values for your chosen provider(s).  #
#                                                                              #
#     cp .env.example .env                                                     #
#                                                                              #
#  The system supports THREE code companion backends:                          #
#    1. GitHub Copilot   (default)  — uses GitHub Copilot via VS Code          #
#    2. Claude API       (direct)   — uses Anthropic API via Claude Code CLI   #
#    3. AWS Bedrock      (cloud)    — uses Claude via AWS Bedrock              #
#                                                                              #
#  You only need to configure the backend(s) you intend to use.                #
###############################################################################


###############################################################################
# SECTION 1: AGENT SELECTION                                                   #
#                                                                              #
#  Controls which AI backend the CodeGenerator uses.                           #
#  Set to "github_copilot" or "claude".                                        #
#                                                                              #
#  NOTE: AWS Bedrock is NOT a separate agent type — it is a backend for the    #
#  Claude agent. Set AGENT_TYPE=claude and then enable Bedrock (see Section 4).#
###############################################################################

AGENT_TYPE=github_copilot


###############################################################################
# SECTION 2: GITHUB COPILOT CONFIGURATION                                     #
#                                                                              #
#  Required when: AGENT_TYPE=github_copilot                                    #
#                                                                              #
#  Prerequisites:                                                              #
#    - Active GitHub Copilot subscription (Individual, Business, or Enterprise)#
#    - VS Code with GitHub Copilot extension installed and signed in           #
#    - A GitHub Personal Access Token (PAT) with copilot scope                 #
#                                                                              #
#  How to get a PAT:                                                           #
#    1. Go to https://github.com/settings/tokens                               #
#    2. Generate new token (classic) → select "copilot" scope                  #
#    3. Copy the token and paste below                                         #
#                                                                              #
#  Supported models (set via GITHUB_COPILOT_MODEL):                            #
#    - gpt-5.3-codex   (default, most capable for code generation)             #
#    - gpt-4o          (fast, good general-purpose)                            #
#    - claude-sonnet-4  (Claude Sonnet via Copilot proxy)                      #
#    - o1              (reasoning-focused)                                      #
###############################################################################

COPILOT_GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXX
GITHUB_COPILOT_MODEL=gpt-5.3-codex
GITHUB_COPILOT_TIMEOUT=900


###############################################################################
# SECTION 3: CLAUDE API CONFIGURATION (Direct Anthropic API)                   #
#                                                                              #
#  Required when: AGENT_TYPE=claude (without Bedrock)                          #
#                                                                              #
#  This uses the Claude Code CLI under the hood, which is bundled with the     #
#  claude-agent-sdk Python package. No separate CLI install needed.            #
#                                                                              #
#  Prerequisites:                                                              #
#    - Anthropic API key from https://console.anthropic.com/                   #
#    - pip install agent-framework-claude (included in agent-framework[all])   #
#                                                                              #
#  How to get an API key:                                                      #
#    1. Go to https://console.anthropic.com/                                   #
#    2. Navigate to API Keys → Create Key                                      #
#    3. Copy the key (starts with sk-ant-)                                     #
#                                                                              #
#  Supported models (set via CLAUDE_MODEL):                                    #
#    - sonnet   (default, balanced speed and quality)                          #
#    - opus     (most capable, slower)                                         #
#    - haiku    (fastest, best for simple tasks)                               #
#                                                                              #
#  Architecture:                                                               #
#    CodeGenerator → ClaudeAgent (MAF) → ClaudeSDKClient → Claude Code CLI    #
#    The CLI is a subprocess that handles tool use, file I/O, and agentic      #
#    capabilities. Your ANTHROPIC_API_KEY is used by the CLI to call the       #
#    Anthropic Messages API directly.                                          #
###############################################################################

ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLAUDE_MODEL=sonnet
CLAUDE_CODE_MAX_OUTPUT_TOKENS=92000


###############################################################################
# SECTION 4: AWS BEDROCK CONFIGURATION                                         #
#                                                                              #
#  Required when: AGENT_TYPE=claude AND you want to route through AWS Bedrock  #
#                                                                              #
#  This is NOT a separate agent type. It changes where the Claude Code CLI     #
#  sends LLM requests — from Anthropic's API to AWS Bedrock's Invoke API.     #
#  All agentic capabilities (tool use, file I/O) are preserved.               #
#                                                                              #
#  How it works:                                                               #
#    CodeGenerator → ClaudeAgent (MAF) → ClaudeSDKClient → Claude Code CLI    #
#    The CLI sees CLAUDE_CODE_USE_BEDROCK=1 in the environment and routes      #
#    all LLM calls through Bedrock instead of the Anthropic API.              #
#    ANTHROPIC_API_KEY is ignored when Bedrock is active.                      #
#                                                                              #
#  Prerequisites:                                                              #
#    1. AWS account with Bedrock access enabled                                #
#    2. Claude models enabled in Bedrock (one-time use case form submission):  #
#       - Go to AWS Console → Amazon Bedrock → Model catalog                   #
#       - Select Anthropic Claude model → submit use case form                 #
#       - Access is granted immediately after submission                       #
#    3. IAM permissions (attach to your IAM user/role):                        #
#       - bedrock:InvokeModel                                                  #
#       - bedrock:InvokeModelWithResponseStream                                #
#       - bedrock:ListInferenceProfiles                                        #
#    4. AWS credentials via one of:                                            #
#       - Access key + secret (shown below)                                    #
#       - AWS CLI profile: aws configure                                       #
#       - SSO: aws sso login --profile=<name>, then set AWS_PROFILE            #
#       - Bedrock API key: set AWS_BEARER_TOKEN_BEDROCK                        #
#                                                                              #
#  To enable:  Set CLAUDE_CODE_USE_BEDROCK=1                                   #
#  To disable: Set CLAUDE_CODE_USE_BEDROCK=0 or remove the line               #
#              (falls back to ANTHROPIC_API_KEY for direct API calls)          #
#                                                                              #
#  Available AWS regions for Bedrock Claude models:                            #
#    us-east-1, us-west-2, eu-west-1, ap-northeast-1, ap-southeast-1          #
#    (check AWS docs for latest availability)                                  #
###############################################################################

CLAUDE_CODE_USE_BEDROCK=1
AWS_REGION=us-east-1

# --- Option A: Access Key credentials (simplest for dev) ---
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_SESSION_TOKEN=                  # Only if using temporary credentials (STS)

# --- Option B: AWS CLI profile (preferred for SSO / multi-account) ---
# Uncomment and use instead of access keys:
# AWS_PROFILE=your-profile-name

# --- Option C: Bedrock API Key (simplest, no full AWS credentials needed) ---
# AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key

# --- Model Pinning (recommended for Bedrock) ---
# Pin specific model versions to prevent breakage when Anthropic releases new
# versions that haven't been enabled in your Bedrock account yet.
# Without pinning, "sonnet" resolves to the latest available version.
# ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-6
# ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Custom Bedrock Endpoint (for gateways / VPC endpoints) ---
# ANTHROPIC_BEDROCK_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com

# --- Haiku Region Override (if Haiku is in a different region) ---
# ANTHROPIC_SMALL_FAST_MODEL_AWS_REGION=us-west-2


###############################################################################
# SECTION 5: QUICK REFERENCE — WHICH VARIABLES FOR WHICH BACKEND?             #
#                                                                              #
#  ┌─────────────────────┬─────────────────┬───────────┬───────────────────┐   #
#  │ Variable            │ GitHub Copilot  │ Claude API│ Claude + Bedrock  │   #
#  ├─────────────────────┼─────────────────┼───────────┼───────────────────┤   #
#  │ AGENT_TYPE          │ github_copilot  │ claude    │ claude            │   #
#  │ COPILOT_GITHUB_TOKEN│ ✅ required     │ —         │ —                 │   #
#  │ GITHUB_COPILOT_MODEL│ ✅ optional     │ —         │ —                 │   #
#  │ ANTHROPIC_API_KEY   │ —               │ ✅ required│ — (ignored)      │   #
#  │ CLAUDE_MODEL        │ —               │ ✅ optional│ ✅ optional       │   #
#  │ CLAUDE_CODE_USE_BEDROCK│ —            │ — (unset) │ ✅ =1             │   #
#  │ AWS_REGION          │ —               │ —         │ ✅ required        │   #
#  │ AWS_ACCESS_KEY_ID   │ —               │ —         │ ✅ required*       │   #
#  │ AWS_SECRET_ACCESS_KEY│ —              │ —         │ ✅ required*       │   #
#  └─────────────────────┴─────────────────┴───────────┴───────────────────┘   #
#                                                                              #
#  * Or use AWS_PROFILE / AWS_BEARER_TOKEN_BEDROCK instead of access keys.     #
###############################################################################


###############################################################################
# SECTION 6: OTHER API KEYS (optional, for other project features)            #
###############################################################################

# OpenAI (if used elsewhere in the project)
# OPENAI_API_KEY=sk-proj-XXXXXXXXXXXX
# OPENAI_RESPONSE_MODEL=gpt-4o-mini

# Google / Gemini
# GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# LangSmith (tracing and observability)
# LANGSMITH_API_KEY=lsv2_pt_XXXXXXXXXXXX
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=your-project-name
